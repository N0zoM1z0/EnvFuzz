*/lib*.so*      # Old ld.so is too buggy
/dev/zero       # Must always be zeroes
/proc/*         # Structured input
/etc/nsswitch.conf # Focus nano campaign away from glibc NSS config parsing
/etc/locale.alias # Focus nano campaign away from glibc locale alias parsing
/usr/share/nano/*.nanorc # Focus nano campaign away from syntax-definition parsing
/usr/lib/locale/* # Focus nano campaign away from glibc locale parsing
/usr/lib/x86_64-linux-gnu/gconv/* # Focus nano campaign away from glibc gconv parsing
/usr/share/locale/* # Focus nano campaign away from translated message catalogs
/usr/share/terminfo/* # Focus nano campaign away from terminal database parsing
netlink://*     # Structured input
pipe://*        # Self-pipe
event://*       # Special fd
epoll://*       # Special fd
